# Copy to `.env.local` (recommended) or `.env` and fill in values.

# Required: gate for /tools/* UI and POST /api/convert
PASSWORD=

# Required: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the default model used for both extraction and spreadsheet generation.
# Examples: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=

# Google Cloud Vision — split fields from the service account JSON key file.
# For VISION_CREDENTIALS_TYPE, paste the JSON "type" value (same as in the downloaded key).
VISION_CREDENTIALS_TYPE=
VISION_CREDENTIALS_PROJECT_ID=
VISION_CREDENTIALS_PRIVATE_KEY_ID=
VISION_CREDENTIALS_PRIVATE_KEY=
VISION_CREDENTIALS_CLIENT_EMAIL=
VISION_CREDENTIALS_CLIENT_ID=

# Vercel Blob (read/write token from Vercel → Storage → Blob). Required on Vercel so large
# file batches upload directly to Blob instead of hitting the ~4.5 MB serverless request limit.
BLOB_READ_WRITE_TOKEN=
